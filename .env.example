# ============================================================
# Skyblue Asset Register — Environment Variables
# คัดลอกไฟล์นี้เป็น .env.local แล้วใส่ค่าจริง
# ============================================================

# --- Supabase ---
# ได้จาก Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role (ใช้ฝั่ง server เท่านั้น — ห้าม expose)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- App Config ---
NEXT_PUBLIC_APP_NAME=Skyblue Asset Register
NEXT_PUBLIC_COMPANY_NAME=Skyblue Construction Co., Ltd.

# --- Storage ---
# ชื่อ bucket ใน Supabase Storage
NEXT_PUBLIC_STORAGE_BUCKET=asset-files
